---
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Crônicas de Maresia — capítulos ilustrados de uma campanha solo de D&D.' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Crônicas de Maresia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="pular-conteudo" href="#conteudo">Pular para o conteúdo</a>
    <header class="cabecalho">
      <nav class="cabecalho__nav">
        <a class="cabecalho__marca" href={`${import.meta.env.BASE_URL}`}>Crônicas de Maresia</a>
        <div class="cabecalho__links">
          <a href={`${import.meta.env.BASE_URL}personagem`}>Personagem</a>
          <a href={`${import.meta.env.BASE_URL}mundo`}>Mundo</a>
          <a href={`${import.meta.env.BASE_URL}personagens`}>NPCs</a>
          <a href={`${import.meta.env.BASE_URL}bestiario`}>Bestiário</a>
          <a href={`${import.meta.env.BASE_URL}estatisticas`}>Estatísticas</a>
          <a href={`${import.meta.env.BASE_URL}memorial`}>Memorial</a>
          <a href={`${import.meta.env.BASE_URL}sobre`}>Sobre</a>
        </div>
      </nav>
    </header>
    <main id="conteudo">
      <slot />
    </main>
    <Footer />
    <style is:global>
      :root {
        --cor-fundo: #0b0805;
        --cor-fundo-elevado: #18100a;
        --cor-texto: #eeddb8;
        --cor-texto-suave: #a4906c;
        --cor-acento: #bd8a3f;
        --cor-acento-suave: #7d5b26;
        --cor-borda: #3a2c17;
        --fonte-corpo: 'EB Garamond', Georgia, 'Times New Roman', serif;
        --fonte-display: 'Cinzel Decorative', Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        background:
          radial-gradient(ellipse 80% 50% at 50% 0%, rgba(189, 138, 63, 0.07), transparent 60%),
          var(--cor-fundo);
        color: var(--cor-texto);
        font-family: var(--fonte-corpo);
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* moldura dourada gravada — usar nos "momentos-vitrine" (hero, retrato principal,
         imagens em destaque), nunca em cartões repetidos, pra não virar ruído */
      .moldura {
        position: relative;
        box-shadow:
          0 0 0 1px var(--cor-acento),
          0 0 0 6px var(--cor-fundo-elevado),
          0 0 0 7px var(--cor-acento-suave);
      }
      .moldura::before,
      .moldura::after {
        content: '✦';
        position: absolute;
        color: var(--cor-acento);
        font-size: 0.85rem;
        line-height: 1;
        z-index: 1;
      }
      .moldura::before {
        top: -0.6rem;
        left: -0.6rem;
      }
      .moldura::after {
        bottom: -0.6rem;
        right: -0.6rem;
      }

      /* anel de medalhão — retratos-vitrine (não os thumbnails repetidos de galeria) */
      .medalhao {
        box-shadow:
          0 0 0 2px var(--cor-fundo),
          0 0 0 3px var(--cor-acento-suave),
          0 0 0 4px var(--cor-acento);
      }

      main {
        flex: 1;
      }

      .pular-conteudo {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--cor-acento);
        color: var(--cor-fundo);
        padding: 0.75rem 1.25rem;
        z-index: 100;
      }
      .pular-conteudo:focus {
        left: 1rem;
        top: 1rem;
      }

      h1,
      h2,
      h3,
      h4 {
        line-height: 1.3;
        color: var(--cor-texto);
      }
      h1 {
        font-family: var(--fonte-display);
        font-weight: 700;
        letter-spacing: 0.01em;
        text-transform: uppercase;
      }
      h2,
      h3,
      h4 {
        font-family: var(--fonte-corpo);
        font-style: italic;
        font-weight: 600;
      }

      a {
        color: var(--cor-acento);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      .cabecalho {
        border-bottom: 1px solid var(--cor-borda);
        background: var(--cor-fundo-elevado);
      }
      .cabecalho__nav {
        max-width: 72rem;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 1.5rem;
        align-items: center;
        justify-content: space-between;
      }
      .cabecalho__marca {
        font-family: var(--fonte-corpo);
        font-style: italic;
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--cor-acento);
        letter-spacing: 0.01em;
      }
      .cabecalho__marca:hover {
        text-decoration: none;
        color: var(--cor-texto);
      }
      .cabecalho__links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 1.25rem;
        font-size: 0.95rem;
      }
      .cabecalho__links a {
        color: var(--cor-texto-suave);
      }
      .cabecalho__links a:hover {
        color: var(--cor-acento);
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
    </style>
  </body>
</html>
