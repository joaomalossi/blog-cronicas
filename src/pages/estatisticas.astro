---
import Layout from '../layouts/Layout.astro';
import stats from '../data/stats.json';

const tiles = [
  { rotulo: 'Sessões jogadas', valor: stats.sessoes_jogadas },
  { rotulo: 'Rolagens totais', valor: stats.total_rolagens },
  { rotulo: 'Combates', valor: stats.combates },
  { rotulo: 'Críticos (20 natural)', valor: stats.criticos },
  { rotulo: 'Falhas críticas (1 natural)', valor: stats.falhas_criticas },
  { rotulo: 'Quase-mortes', valor: stats.quase_mortes },
  { rotulo: 'Mortes de PJ', valor: stats.mortes_pj },
];

const posicaoBarra = Math.min(100, Math.max(0, (stats.d20_medio / 20) * 100));
---

<Layout title="Estatísticas" description="Números agregados da campanha — sem spoiler, sem motivo de rolagem.">
  <article class="pagina">
    <h1>Estatísticas da campanha</h1>
    <p class="pagina__intro">
      Só agregados — nenhuma rolagem individual ou motivo aparece aqui, pra não vazar spoiler.
    </p>

    <section class="grafico">
      <h2>d20 médio: {stats.d20_medio.toFixed(2)}</h2>
      <svg viewBox="0 0 400 40" class="grafico__barra" role="img" aria-label={`Média de resultado do d20: ${stats.d20_medio.toFixed(2)} em 20`}>
        <rect x="0" y="15" width="400" height="10" rx="5" fill="var(--cor-borda)" />
        <rect x="0" y="15" width={posicaoBarra * 4} height="10" rx="5" fill="var(--cor-acento)" />
        <circle cx={posicaoBarra * 4} cy="20" r="9" fill="var(--cor-acento)" />
      </svg>
      <div class="grafico__eixo">
        <span>1</span>
        <span>10,5 (esperado)</span>
        <span>20</span>
      </div>
    </section>

    <ul class="tiles">
      {tiles.map((tile) => (
        <li class="tile">
          <span class="tile__valor">{tile.valor}</span>
          <span class="tile__rotulo">{tile.rotulo}</span>
        </li>
      ))}
    </ul>
  </article>
</Layout>

<style>
  .pagina {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .pagina__intro {
    color: var(--cor-texto-suave);
  }
  .grafico {
    margin: 2rem 0 3rem;
  }
  .grafico h2 {
    font-size: 1.1rem;
  }
  .grafico__barra {
    width: 100%;
    height: 2.5rem;
  }
  .grafico__eixo {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--cor-texto-suave);
  }
  .tiles {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 1rem;
  }
  .tile {
    border: 1px solid var(--cor-borda);
    border-radius: 0.3rem;
    padding: 1.25rem 1rem;
    text-align: center;
  }
  .tile__valor {
    display: block;
    font-family: var(--fonte-display);
    font-size: 2rem;
    color: var(--cor-acento);
  }
  .tile__rotulo {
    display: block;
    font-size: 0.8rem;
    color: var(--cor-texto-suave);
    margin-top: 0.35rem;
  }
</style>
